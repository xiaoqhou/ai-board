{
	"name": "Nix Environment",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"remoteUser": "vscode",
	"features": {
		"ghcr.io/devcontainers/features/nix:1": {
			"extraNixConfig": "experimental-features = nix-command flakes",
			"packages": "git,git-lfs,curl,jq,vim,bat,direnv,fish,nodejs,uv,go,devbox"
		},
		"ghcr.io/devcontainers-community/features/direnv:1": {},
		"ghcr.io/devcontainers/features/sshd:1": {}
	},
	"postCreateCommand": {
		"direnv-allow": "direnv allow /workspaces/ai-board",
		"hide-direnv-diff": "mkdir -p ~/.config/direnv && echo '[global]\\nhide_env_diff = true' > ~/.config/direnv/direnv.toml && direnv allow"
	},
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "fish"
			}
		}
	}
}