{
	"name": "Nix Environment from Dockerfile",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"remoteUser": "vscode",
	"overrideCommand": false,
	"forwardPorts": [
		4096
	],
	"portsAttributes": {
		"4096": {
			"label": "Opencode public",
			"visibility": "public",
			"protocol": "http"
		}
	},
	"customizations": {
		"vscode": {
			"settings": {
				"terminal.integrated.defaultProfile.linux": "fish"
			}
		}
	}
}